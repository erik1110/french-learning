          {"fr": "février", "zh": "二月"},
          {"fr": "mars", "zh": "三月"},
          {"fr": "avril", "zh": "四月"},
          {"fr": "mai", "zh": "五月"},
          {"fr": "juin", "zh": "六月"},
          {"fr": "juillet", "zh": "七月"},
          {"fr": "août", "zh": "八月"},
          {"fr": "septembre", "zh": "九月"},
          {"fr": "octobre", "zh": "十月"},
